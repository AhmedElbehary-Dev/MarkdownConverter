<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MarkdownConverter.ViewModels;assembly=MarkdownConverter.Core"
        x:Class="MarkdownConverter.Desktop.UI.PdfCompressorWindow"
        mc:Ignorable="d"
        Width="680"
        Height="560"
        MinWidth="600"
        MinHeight="480"
        Title="PDF Compressor - Markdown Converter Pro"
        Icon="avares://MarkdownConverter.Desktop/Assets/md_converter.ico"
        Background="{DynamicResource AppBgBrush}">

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style Selector="Border.subtle">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="Button">
      <Setter Property="Background" Value="{DynamicResource PanelInsetBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="#091318" />
      <Setter Property="BorderBrush" Value="#34D2D9" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#202733" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="18">
    <!-- Header -->
    <Border Grid.Row="0" Classes="card" Padding="16">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Border Width="56" Height="56" CornerRadius="12" Background="White" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1">
          <Image Source="avares://MarkdownConverter.Desktop/Assets/md_converter.png" Stretch="Uniform" Margin="6" />
        </Border>

        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center" Margin="16,0,16,0">
          <TextBlock Text="PDF Compressor" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Text="Reduce PDF file size with smart compression" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" />
        </StackPanel>

        <Button Grid.Column="2" Content="Select PDF" Classes="primary" Command="{Binding BrowsePdfCommand}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Main Content -->
    <Border Grid.Row="1" Classes="card" Margin="0,16,0,12" Padding="24">
      <StackPanel Spacing="20" VerticalAlignment="Center">

        <!-- File info -->
        <Border Classes="subtle" Padding="16" IsVisible="{Binding HasFile}">
          <StackPanel Spacing="6">
            <TextBlock Text="Selected File" FontWeight="SemiBold" FontSize="14" />
            <TextBlock Text="{Binding InputFilePath}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
          </StackPanel>
        </Border>

        <!-- Empty state -->
        <StackPanel Spacing="12" HorizontalAlignment="Center" IsVisible="{Binding !HasFile}">
          <Border Classes="subtle" Width="54" Height="54" CornerRadius="14" HorizontalAlignment="Center">
            <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
          </Border>
          <TextBlock Text="No PDF selected" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
          <TextBlock Text="Choose a PDF file to compress its size"
                     Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Quality selector -->
        <StackPanel Spacing="6" IsVisible="{Binding HasFile}">
          <TextBlock Text="Compression Quality" FontWeight="SemiBold" FontSize="14" />
          <ComboBox ItemsSource="{Binding QualityLabels}"
                    SelectedIndex="{Binding SelectedQualityIndex}"
                    HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- Size stats -->
        <Border Classes="subtle" Padding="16" IsVisible="{Binding HasFile}">
          <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,Auto">
            <!-- Original -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="Original Size" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding OriginalSizeText}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Arrow -->
            <TextBlock Grid.Column="1" Text="→" FontSize="24" VerticalAlignment="Center" 
                       Foreground="{DynamicResource AccentBrush}" Margin="16,0" />

            <!-- Compressed -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="Compressed Size" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding CompressedSizeText}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
              <TextBlock Text="—" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" IsVisible="{Binding !HasResult}" />
            </StackPanel>

            <!-- Reduction badge -->
            <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0"
                    Background="#1A2B3D" CornerRadius="8" Padding="12,6"
                    HorizontalAlignment="Center" IsVisible="{Binding HasResult}">
              <TextBlock Text="{Binding ReductionText}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="14" />
            </Border>
          </Grid>
        </Border>
      </StackPanel>
    </Border>

    <!-- Footer -->
    <Border Grid.Row="2" Classes="subtle" Padding="16">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Content="Replace Original" Command="{Binding ReplaceOriginalCommand}" IsEnabled="{Binding !IsCompressing}" />
          <Button Content="Save As" Classes="primary" Command="{Binding CompressCommand}" IsEnabled="{Binding !IsCompressing}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
